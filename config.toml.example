[lavalink]
host     = "lavalink:2333"
password = "youshallnotpass"

[storage]
data_dir = "./data"
# db_path defaults to "{data_dir}/pedmin.db" if omitted
# db_path = "./data/pedmin.db"

[player]
default_volume     = 50    # 0–200
auto_leave_timeout = 180   # seconds, 0 = disabled

[presence]
interval = 30   # seconds, 5–600

[timeouts]
lavalink           = 2    # seconds, 1–30
lavalink_load      = 10   # seconds, 5–60
http_client        = 10   # seconds, 5–60
panel_power_action = 15   # seconds, 5–60

[rss]
poll_interval = 300   # seconds, 60–3600
feed_timeout  = 30    # seconds, 10–120

[url]
shorten_timeout = 10   # seconds, 5–60
scan_timeout    = 15   # seconds, 5–120

log_level = "info"   # debug, info, warn, error

[panel]
url           = ""
allowed_users = []
